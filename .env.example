# ---- PCR Pilot env ----
# DEMO ONLY. Sample data only. Not for real patient information.

# Supabase project (free tier is fine for the demo)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Service-role key (server-only — used by API routes for inserts/updates).
# NEVER prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Storage bucket name (create in Supabase → Storage → New bucket, public)
SUPABASE_STORAGE_BUCKET=pcr-uploads

# Anthropic (Claude) — for OCR field extraction, vision fallback, narrative generation
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — OPTIONAL. Only needed for Whisper audio transcription.
# If not provided, voice recording will upload but transcription will return empty.
# Get your key at: https://platform.openai.com
OPENAI_API_KEY=sk-...

# Optional: Postgres connection string for "npm run db:push" psql-based seed.
# Find it in Supabase → Project Settings → Database → Connection string (URI).
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.YOUR-PROJECT.supabase.co:5432/postgres

# Optional future swap: provide a Google Maps Places API key to swap Nominatim
# for Google Places. Not required for v1.
# GOOGLE_PLACES_API_KEY=
